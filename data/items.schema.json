{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "urn:items",
	"title": "Item Entries",
	"description": "Checked acceptable",
	"type": "object",
	"propertyNames": {
		"pattern": "^[A-Z][a-z0-9]+(?:[A-Z][a-z0-9]+)*$"
	},
	"additionalProperties": {
		"type": "object",
		"properties": {
			"item_name": {
				"type": "string"
			},
			"unit_weight": {
				"type": "number"
			},
			"tags": {
				"$ref": "urn:shared#/$defs/tags"
			}
		},
		"required": [
			"item_name",
			"unit_weight",
			"tags"
		]
	}
}