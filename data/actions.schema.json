{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "urn:actions",
	"title": "Action Entries",
	"description": "Checked acceptable",
	"type": "object",
	"propertyNames": {
		"pattern": "^[A-Z][a-z0-9]+(?:[A-Z][a-z0-9]+)*$"
	},
	"additionalProperties": {
		"type": "object",
		"properties": {
			"action_name": {
				"type": "string"
			},
			"action": {
				"type": "string"
			},
			"time": {
				"type": "number"
			},
			"reqs": {
				"$ref": "urn:shared#/$defs/exchange"
			},
			"rews": {
				"$ref": "urn:shared#/$defs/exchange"
			},
			"tags": {
				"$ref": "urn:shared#/$defs/tags"
			}
		},
		"required": [
			"action_name",
			"action",
			"reqs",
			"rews",
			"tags"
		]
	}
}